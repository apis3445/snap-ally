{
    "name": "snap-ally",
    "version": "0.1.1-beta",
    "description": "A custom Playwright reporter for Accessibility testing using Axe, with HTML reporting and Azure DevOps integration.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc && mkdir -p dist/templates && cp -R src/templates/* dist/templates/",
        "prepublishOnly": "npm run build",
        "test": "npx playwright test --project=chromium",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write ."
    },
    "keywords": [
        "playwright",
        "accessibility",
        "a11y",
        "reporter",
        "axe"
    ],
    "author": "Abigail Armijo",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/apis3445/snap-ally.git"
    },
    "dependencies": {
        "@axe-core/playwright": "^4.11.1"
    },
    "peerDependencies": {
        "@playwright/test": "^1.58.2",
        "playwright": "^1.58.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-playwright": "^2.9.0",
        "jsdom": "^28.1.0",
        "prettier": "^3.8.1",
        "typescript": "^5.0.0"
    }
}